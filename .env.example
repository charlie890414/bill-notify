# Bill Notification System Environment Variable Configuration

# OpenRouter API Key (required)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# Optional: UID/GID used by Docker Compose for writable bind mounts.
# Use `id -u` and `id -g` on the host.
# PUID=1026
# PGID=100

# Optional: Configuration file path (defaults to config.yaml)
# CONFIG_FILE=config.yaml

# Optional: Gmail and Google OAuth settings
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_TOKEN_FILE=token.json
# GMAIL_LABEL=bills
# GMAIL_DAYS_BACK=7

# Optional: Calendar settings
# CALENDAR_ID=primary
# REMINDER_DAYS=7,3,1

# Optional: OpenRouter model
# OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Optional: Local files and directories
# DOWNLOAD_DIR=./downloads
# PROCESSED_LOG=./processed_emails.log

# Optional: PDF passwords file path (defaults to pdf_passwords.yaml)
# PDF_PASSWORDS_FILE=pdf_passwords.yaml
