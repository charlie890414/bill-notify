# Bill Notification System Environment Variable Configuration

# OpenRouter API Key (required)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# Optional: Configuration file path (defaults to config.yaml)
# CONFIG_FILE=config.yaml

# Optional: PDF passwords file path (defaults to pdf_passwords.yaml)
# PDF_PASSWORDS_FILE=pdf_passwords.yaml

# Optional: PDF processing engine (defaults to pdf-text)
# Overrides config.yaml setting if set